<Window x:Class="SillyDis.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        Background="{StaticResource BrushBgDeepNavy}"
        Foreground="{StaticResource BrushTextPrimary}"
        FontFamily="Segoe UI"
        Title="SillyDis — IEEE-1278.1 DIS Inspector" Height="820" Width="1520">

    <materialDesign:DialogHost x:Name="DialogHost" IsOpen="{Binding IsDialogOpen}">

        <!-- ══ Profile Edit Dialog ══ -->
        <materialDesign:DialogHost.DialogContent>
            <Border Style="{StaticResource CardBorderStyle}" Padding="24" Width="360">
                <StackPanel>
                    <TextBlock Text="NETWORK PROFILE" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBox materialDesign:HintAssist.Hint="Profile Name"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding EditingProfile.Name}" Margin="0,8" />
                    <TextBox materialDesign:HintAssist.Hint="Multicast Address (e.g. 239.1.2.3)"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding EditingProfile.MulticastAddress}" Margin="0,5" />
                    <TextBox materialDesign:HintAssist.Hint="UDP Port"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding EditingProfile.Port}" Margin="0,5" />
                    <!-- NIC Picker ComboBox (WS2) -->
                    <ComboBox x:Name="NicComboBox"
                              materialDesign:HintAssist.Hint="Local Network Interface"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              DisplayMemberPath="."
                              Margin="0,5"
                              SelectionChanged="NicComboBox_SelectionChanged" />
                    <TextBox materialDesign:HintAssist.Hint="Local NIC IP (auto-filled above)"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding EditingProfile.LocalInterfaceIp}" Margin="0,5" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="CANCEL" Command="{Binding CancelProfileCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0" />
                        <Button Content="SAVE" Command="{Binding SaveProfileCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="440" />
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT: Network Profiles ══ -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="12,12,12,0">
                        <TextBlock Text="// NETWORK PROFILES" Style="{StaticResource SectionHeaderStyle}" />
                        <!-- Connection status bar -->
                        <Border Background="#0D1220" CornerRadius="3" Padding="8,4" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource StatusIdle}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsListening}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource StatusListening}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontFamily="Consolas" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="IDLE" />
                                            <Setter Property="Foreground" Value="{StaticResource BrushAccentMuted}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsListening}" Value="True">
                                                    <Setter Property="Text" Value="LISTENING" />
                                                    <Setter Property="Foreground" Value="{StaticResource BrushAccentGreen}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Dropped packet counter -->
                                <TextBlock Style="{StaticResource MonoTextStyle}" FontSize="10"
                                           Foreground="{StaticResource BrushAccentRed}"
                                           Margin="12,0,0,0"
                                           Text="{Binding DroppedPacketCount, StringFormat='dropped: {0}'}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             Background="Transparent" BorderThickness="0" Margin="8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2" CornerRadius="3" Background="#0D1220">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource StatusIdle}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Listening">
                                                            <Setter Property="Fill" Value="{StaticResource StatusListening}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Fill" Value="{StaticResource StatusFailed}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrushTextPrimary}" FontSize="13" />
                                            <TextBlock Style="{StaticResource MonoTextStyle}" FontSize="11"
                                                       Text="{Binding MulticastAddress}" Opacity="0.7" />
                                            <TextBlock Style="{StaticResource MonoTextStyle}" FontSize="10"
                                                       Text="{Binding Port, StringFormat=':{}:{0}'}" Opacity="0.5" />
                                        </StackPanel>
                                        <Button Grid.Column="2" Width="22" Height="22" Padding="0"
                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                Command="{Binding DataContext.EditProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="Pencil" Width="13" Height="13" />
                                        </Button>
                                        <Button Grid.Column="3" Width="22" Height="22" Padding="0"
                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                Foreground="{StaticResource BrushAccentRed}"
                                                Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="Delete" Width="13" Height="13" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="8,0,8,8">
                        <Button Content="DISCONNECT" Command="{Binding DisconnectCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,4"
                                Foreground="{StaticResource BrushAccentAmber}"
                                BorderBrush="{StaticResource BrushAccentAmber}" />
                        <Button Content="+ ADD PROFILE" Command="{Binding AddProfileCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource BrushAccentGreen}" Foreground="#0A0E1A"
                                FontWeight="Bold" />
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent" />

            <!-- ══ MIDDLE: PDU Sessions + Tactical Map ══ -->
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6"
                                HorizontalAlignment="Right">
                        <!-- Export Capture -->
                        <Button Command="{Binding DataContext.ExportCaptureCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource BrushAccentGreen}"
                                BorderBrush="{StaticResource BrushAccentGreen}"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                ToolTip="Export capture to NDJSON / JSON"
                                Content="⬇ EXPORT" Margin="0,0,8,0" />
                        <!-- Add Session -->
                        <Button Command="{Binding AddSessionCommand}"
                                Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                Background="{StaticResource BrushAccentGreen}" Foreground="#0A0E1A"
                                ToolTip="New Session Tab" Width="28" Height="28">
                            <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" />
                        </Button>
                    </StackPanel>

                    <TabControl Grid.Row="1" Background="Transparent"
                                BorderBrush="#1E2D45"
                                ItemsSource="{Binding Sessions}"
                                SelectedItem="{Binding SelectedSession}"
                                SelectionChanged="TabControl_SelectionChanged">

                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Text="{Binding Header, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             FontFamily="Consolas" FontSize="12"
                                             Foreground="{StaticResource BrushTextPrimary}"
                                             VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <Button Command="{Binding DataContext.CloseSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Width="18" Height="18" Padding="0">
                                        <materialDesign:PackIcon Kind="Close" Width="11" Height="11" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>

                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Filter bar -->
                                    <Border Grid.Row="0" Background="#0A0E1A" Padding="6,4">
                                        <WrapPanel Orientation="Horizontal">
                                            <!-- Exercise ID: editable ComboBox auto-populated from live traffic -->
                                            <ComboBox materialDesign:HintAssist.Hint="Ex ID (0=any)"
                                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                                      IsEditable="True"
                                                      Text="{Binding TargetExerciseId, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding ObservedExerciseIds}"
                                                      FontFamily="Consolas" Width="130" Margin="4,0,4,6" />
                                            <ComboBox materialDesign:HintAssist.Hint="PDU Type"
                                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                                      SelectedItem="{Binding TargetPduType}"
                                                      Width="150" Margin="4,0,4,6">
                                                <ComboBoxItem>Any</ComboBoxItem>
                                                <ComboBoxItem>Entity State</ComboBoxItem>
                                                <ComboBoxItem>Fire</ComboBoxItem>
                                                <ComboBoxItem>Detonation</ComboBoxItem>
                                                <ComboBoxItem>Collision</ComboBoxItem>
                                                <ComboBoxItem>Create Entity</ComboBoxItem>
                                                <ComboBoxItem>Remove Entity</ComboBoxItem>
                                                <ComboBoxItem>Electromagnetic Emissions</ComboBoxItem>
                                                <ComboBoxItem>Designator</ComboBoxItem>
                                                <ComboBoxItem>Transmitter</ComboBoxItem>
                                                <ComboBoxItem>Comment</ComboBoxItem>
                                            </ComboBox>
                                            <TextBox materialDesign:HintAssist.Hint="Entity ID"
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                     Text="{Binding TargetEntityId, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas" Width="140" Margin="4,0,4,6" />
                                            <TextBox materialDesign:HintAssist.Hint="Regex Filter"
                                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                     Text="{Binding TargetRegexFilter, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="130" Margin="4,0,4,6" />

                                            <!-- Pause mode toggle -->
                                            <ComboBox materialDesign:HintAssist.Hint="Pause Mode"
                                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                                      SelectedItem="{Binding PauseMode}"
                                                      Width="90" Margin="4,0,4,6" />

                                            <!-- Pause/Resume button -->
                                            <ToggleButton IsChecked="{Binding IsPaused, Mode=OneWay}"
                                                          Command="{Binding TogglePauseCommand}"
                                                          Margin="4,4,4,6" Padding="10,4">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                        <Setter Property="Content" Value="⏸ PAUSE" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                                <Setter Property="Content" Value="▶ RESUME" />
                                                                <Setter Property="Background" Value="{StaticResource BrushAccentAmber}" />
                                                                <Setter Property="Foreground" Value="#0A0E1A" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>

                                            <!-- Pause buffer count chip — shown only when paused -->
                                            <Border Background="#1E2D45" CornerRadius="3" Padding="6,4" Margin="0,4,4,6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Style="{StaticResource MonoTextStyle}" FontSize="10"
                                                           Foreground="{StaticResource BrushAccentAmber}"
                                                           Text="{Binding PauseBufferCount, StringFormat='buf: {0}'}" />
                                            </Border>

                                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                    Command="{Binding ClearFilterCommand}"
                                                    ToolTip="Clear filters" Margin="0,4,4,6">
                                                <materialDesign:PackIcon Kind="FilterRemoveOutline" />
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                    Command="{Binding ClearPdusCommand}"
                                                    ToolTip="Clear PDU list" Margin="0,4,4,6"
                                                    Foreground="{StaticResource BrushAccentRed}">
                                                <materialDesign:PackIcon Kind="TrashCanOutline" />
                                            </Button>
                                        </WrapPanel>
                                    </Border>

                                    <!-- Capture session sub-tabs: Traffic | Tactical Map -->
                                    <TabControl Grid.Row="1" Background="Transparent"
                                                BorderBrush="#1E2D45"
                                                ItemContainerStyle="{StaticResource TacticalTabItemStyle}"
                                                x:Name="InnerTabControl">

                                        <!-- Traffic tab -->
                                        <TabItem Header="📡 TRAFFIC">
                                            <ListView x:Name="PduListView"
                                                      ItemsSource="{Binding Pdus}"
                                                      SelectedItem="{Binding SelectedPdu}"
                                                      ItemContainerStyle="{StaticResource TacticalListViewItem}"
                                                      VirtualizingPanel.IsVirtualizing="True"
                                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                                      Background="{StaticResource BrushBgDeepNavy}"
                                                      SelectionChanged="ListView_SelectionChanged">
                                                <ListView.View>
                                                    <GridView ColumnHeaderContainerStyle="{StaticResource TacticalGridHeaderStyle}">
                                                        <GridViewColumn Header="TIME" Width="88"
                                                            DisplayMemberBinding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" />
                                                        <GridViewColumn Header="PDU TYPE" Width="140"
                                                            DisplayMemberBinding="{Binding PduTypeName}" />
                                                        <GridViewColumn Header="EX" Width="36"
                                                            DisplayMemberBinding="{Binding ExerciseId}" />
                                                        <GridViewColumn Header="ENTITY ID" Width="120"
                                                            DisplayMemberBinding="{Binding EntityId}" />
                                                        <GridViewColumn Header="PLATFORM" Width="160"
                                                            DisplayMemberBinding="{Binding EntityTypeName}" />
                                                        <GridViewColumn Header="FORCE" Width="80"
                                                            DisplayMemberBinding="{Binding ForceIdName}" />
                                                        <GridViewColumn Header="B" Width="50"
                                                            DisplayMemberBinding="{Binding Length}" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </TabItem>

                                        <!-- Tactical Map tab -->
                                        <TabItem Header="🗺 TACTICAL" x:Name="TacticalTabItem">
                                            <mapsui:MapControl x:Name="TacticalMap"
                                                               Background="{StaticResource BrushBgDeepNavy}" />
                                        </TabItem>
                                    </TabControl>
                                </Grid>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent" />

            <!-- ══ RIGHT: PDU Inspector ══ -->
            <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}" Margin="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="200" />
                    </Grid.RowDefinitions>

                    <!-- Inspector header -->
                    <Grid Grid.Row="0" Margin="12,10,12,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="// PDU INSPECTOR" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="⚡ SPOOF &amp; REBROADCAST"
                                Click="RebroadcastButton_Click"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource BrushAccentOrange}" Foreground="#0A0E1A"
                                FontFamily="Consolas" FontWeight="Bold" FontSize="11" />
                    </Grid>

                    <!-- JSON / Hex tabs -->
                    <TabControl Grid.Row="1" Background="Transparent" BorderBrush="#1E2D45">
                        <TabItem Header="{}{} JSON">
                            <avalonEdit:TextEditor x:Name="PduEditor"
                                                   SyntaxHighlighting="JavaScript"
                                                   FontFamily="Consolas, Cascadia Code"
                                                   FontSize="12"
                                                   IsReadOnly="False"
                                                   ShowLineNumbers="True"
                                                   Background="Transparent"
                                                   Foreground="#A8D8EA" />
                        </TabItem>
                        <TabItem Header="⬡ HEX">
                            <avalonEdit:TextEditor x:Name="HexEditor"
                                                   FontFamily="Consolas, Cascadia Code"
                                                   FontSize="12"
                                                   IsReadOnly="True"
                                                   ShowLineNumbers="False"
                                                   Background="Transparent"
                                                   Foreground="#7EC8A0"
                                                   WordWrap="False" />
                        </TabItem>
                    </TabControl>

                    <!-- Telemetry: total + per-type chart -->
                    <Grid Grid.Row="2" Margin="0,4,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="// TELEMETRY  PDUs/sec"
                                   Style="{StaticResource SectionHeaderStyle}" Margin="12,4,0,0" />
                        <scottplot:WpfPlot x:Name="TelemetryPlot" Grid.Row="1"
                                           Background="{StaticResource BrushBgDeepNavy}"
                                           Margin="0,0,0,0" />
                    </Grid>
                </Grid>
            </Border>

        </Grid>
    </materialDesign:DialogHost>
</Window>
