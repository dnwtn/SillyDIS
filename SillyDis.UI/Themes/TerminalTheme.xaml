<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         SillyDis Terminal Theme
         Deep navy base with tactical accent palette and monospaced ID fields.
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Base surfaces -->
    <Color x:Key="BgDeepNavy">#0A0E1A</Color>
    <Color x:Key="BgCard">#111827</Color>
    <Color x:Key="BgCardAlt">#0D1220</Color>
    <Color x:Key="BgRow">#111827</Color>
    <Color x:Key="BgRowAlt">#0D1220</Color>
    <Color x:Key="BgRowSelected">#1E3A5F</Color>
    <Color x:Key="BgRowHover">#172035</Color>

    <!-- Accent palette -->
    <Color x:Key="AccentGreen">#00FF88</Color>       <!-- Active / Connected -->
    <Color x:Key="AccentBlue">#00BFFF</Color>        <!-- ESPDU / info -->
    <Color x:Key="AccentAmber">#FFB300</Color>       <!-- Paused / warning -->
    <Color x:Key="AccentOrange">#FF6B35</Color>      <!-- Fire/Det PDUs -->
    <Color x:Key="AccentRed">#FF4444</Color>         <!-- Error / Dropped -->
    <Color x:Key="AccentMuted">#4A5568</Color>       <!-- Disabled / borders -->

    <!-- Text -->
    <Color x:Key="TextPrimary">#E2E8F0</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color>
    <Color x:Key="TextMono">#A8B4C8</Color>          <!-- Monospaced ID/hex fields -->

    <!-- SolidColorBrushes -->
    <SolidColorBrush x:Key="BrushBgDeepNavy"    Color="{StaticResource BgDeepNavy}" />
    <SolidColorBrush x:Key="BrushBgCard"        Color="{StaticResource BgCard}" />
    <SolidColorBrush x:Key="BrushBgCardAlt"     Color="{StaticResource BgCardAlt}" />
    <SolidColorBrush x:Key="BrushAccentGreen"   Color="{StaticResource AccentGreen}" />
    <SolidColorBrush x:Key="BrushAccentBlue"    Color="{StaticResource AccentBlue}" />
    <SolidColorBrush x:Key="BrushAccentAmber"   Color="{StaticResource AccentAmber}" />
    <SolidColorBrush x:Key="BrushAccentOrange"  Color="{StaticResource AccentOrange}" />
    <SolidColorBrush x:Key="BrushAccentRed"     Color="{StaticResource AccentRed}" />
    <SolidColorBrush x:Key="BrushAccentMuted"   Color="{StaticResource AccentMuted}" />
    <SolidColorBrush x:Key="BrushTextPrimary"   Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="BrushTextMono"      Color="{StaticResource TextMono}" />

    <!-- ── Monospaced field style (EntityId, hex values, timestamps) ──── -->
    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Courier New" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextMono}" />
    </Style>

    <!-- ── Status dot brushes (used in profile list) ─────────────────── -->
    <SolidColorBrush x:Key="StatusIdle"      Color="#4A5568" />
    <SolidColorBrush x:Key="StatusListening" Color="{StaticResource AccentGreen}" />
    <SolidColorBrush x:Key="StatusFailed"    Color="{StaticResource AccentRed}" />

    <!-- ── ListView / GridView row styling ───────────────────────────── -->
    <Style x:Key="TacticalListViewItem" TargetType="ListViewItem">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#1E2D45" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="4,3" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background">
                    <Setter.Value><SolidColorBrush Color="{StaticResource BgRowSelected}" /></Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background">
                    <Setter.Value><SolidColorBrush Color="{StaticResource BgRowHover}" /></Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── GridViewColumnHeader ──────────────────────────────────────── -->
    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#0A0E1A" /></Setter.Value>
        </Setter>
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="#64748B" /></Setter.Value>
        </Setter>
        <Setter Property="FontFamily" Value="Consolas, Cascadia Code" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="BorderBrush">
            <Setter.Value><SolidColorBrush Color="#1E2D45" /></Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <!-- ── Section header TextBlock ──────────────────────────────────── -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas, Cascadia Code" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource BrushAccentGreen}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- ── Tab item ───────────────────────────────────────────────────── -->
    <Style TargetType="TabItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrushAccentGreen}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushAccentGreen}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Card border ───────────────────────────────────────────────── -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush">
            <Setter.Value><SolidColorBrush Color="#1E2D45" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="4" />
    </Style>

</ResourceDictionary>
